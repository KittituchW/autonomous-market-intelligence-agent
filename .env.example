# Free-tier keys you need to run AMIA. Copy this file to `.env` and fill in.

# NewsAPI: 100 requests/day on the free tier. https://newsapi.org/
NEWSAPI_KEY=

# Groq: 100k tokens/day on llama-3.3-70b-versatile. https://console.groq.com/
GROQ_API_KEY=

# Gemini: 1500 requests/day. Used by the critic and as Groq fallback.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Langfuse self-hosted (optional, for tracing). Run via Docker Compose
# from langfuse/langfuse repo. Defaults below assume localhost.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3000
