# Free-tier keys you need to run AMIA. Copy this file to `.env` and fill in.

# NewsAPI: 100 requests/day on the free tier. https://newsapi.org/
NEWSAPI_KEY=

# Groq: 100k tokens/day on llama-3.3-70b-versatile. https://console.groq.com/
GROQ_API_KEY=

# Gemini: 1500 requests/day. Used by the critic and as Groq fallback.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Langfuse self-hosted (optional, for tracing). Run via Docker Compose
# from langfuse/langfuse repo. Defaults below assume localhost.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3000

# Writer override (optional). Default behavior probes local Ollama and falls
# back to Gemini if gemma3:4b isn't reachable. Force one or the other:
#   AMIA_WRITER=local  -> skip the probe, always use Ollama
#   AMIA_WRITER=cloud  -> skip Ollama, always use Gemini 3.1 Flash Lite
# Use "cloud" when you know RAM will be tight (e.g., Chrome + Cursor open).
AMIA_WRITER=
